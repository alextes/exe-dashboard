# Copy to .env (gitignored) and fill in. The dashboard reads these.

# Login password for the dashboard. Defaults to "password" (local dev) if unset.
# In prod, set the real value via env on the VM — do not commit it.
DASHBOARD_PASSWORD=password

# Random secret used to sign the session cookie. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port the dashboard listens on (pick within exe.dev's 3000-9999 proxy range).
PORT=8080

# Agent: address it binds to (keep on localhost; scrape over ssh).
AGENT_BIND=127.0.0.1:9099
